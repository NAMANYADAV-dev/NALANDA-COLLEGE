# ------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values from your
# Supabase project (Project Settings → API). `.env.local` is gitignored.
# ------------------------------------------------------------------

# Public — safe to expose to the browser. Used by both server and client
# Supabase clients. The anon key is protected by Row Level Security (RLS).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER prefix with NEXT_PUBLIC and never use in a Client
# Component. Bypasses RLS; only for trusted server-side admin tasks / seeding.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Canonical site URL (used for metadata, absolute links, auth redirects).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------------------------------------------------------------------
# Email (SMTP) — OPTIONAL. Sends the admin a notification on each new
# enquiry. Enquiries still save fine without this. Provider-agnostic:
#   Gmail  → host smtp.gmail.com, port 587, user <your@gmail.com>,
#            pass = 16-char App Password (see docs/EMAIL_SETUP.md)
#   Resend → host smtp.resend.com, port 465, user "resend", pass <api key>
# ------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Where new-enquiry alerts are sent (defaults to SMTP_USER if blank).
ADMIN_NOTIFY_EMAIL=
